#!/usr/bin/env python3
"""Minify agent-facing markdown files.

Reduces token count in agent instruction files by:
- compacting table padding and separator rows
- collapsing excess blank lines
- unquoting safe YAML frontmatter scalars
- normalising double-brace/bracket spacing
"""

from __future__ import annotations

import argparse
import re
import subprocess
import sys
from pathlib import Path
from typing import Iterable

REPO_ROOT = Path(__file__).resolve().parent.parent
EXCLUDED_PARTS = {'.git', '.github', 'node_modules', 'dist'}
TABLE_ROW_RE = re.compile(r'^(\s*)\|(.*)\|\s*$')
# Characters that force quoting in YAML plain scalars
UNSAFE_FRONTMATTER_START_RE = re.compile(r'^[\[{`>|\'"&!%@?,]|^-(?= )|^:(?= |$)')
# Sequences that force quoting anywhere in a plain scalar
UNSAFE_FRONTMATTER_INLINE_RE = re.compile(r': | #|:\s*$')
YAML_AMBIGUOUS_PLAIN_SCALAR_RE = re.compile(
    r'^(?:'
    r'~|null|true|false|y|yes|n|no|on|off'
    r'|[-+]?\.(?:inf|nan)'
    r'|[-+]?0b[0-1_]+'
    r'|[-+]?0x[0-9a-f_]+'
    r'|[-+]?0o?[0-7_]+'
    r'|[-+]?(?:0|[1-9][0-9_]*)'
    r'|[-+]?(?:[0-9][0-9_]*\.[0-9_]+|\.[0-9_]+)(?:[eE][-+]?[0-9]+)?'
    r'|[-+]?[0-9][0-9_]*(?:[eE][-+]?[0-9]+)'
    r'|[-+]?[0-9][0-9_]*(?::[0-5]?[0-9])+'
    r'|[-+]?[0-9][0-9_]*(?::[0-5]?[0-9])+\.[0-9_]*'
    r'|\d{4}-\d{2}-\d{2}'
    r'|\d{4}-\d{2}-\d{2}(?:[Tt]|[ \t]+)\d{2}:\d{2}:\d{2}(?:\.[0-9]+)?(?:[ \t]*(?:Z|[-+]\d{2}(?::\d{2})?))?'
    r')$',
    re.IGNORECASE,
)

FENCE_RE = re.compile(r'^(?:`{3,}|~{3,})')

# {{ spaced placeholder }} or { { spaced } } → {{compact}}
DOUBLE_BRACE_RE = re.compile(r'\{\s*\{\s*(.*?)\s*\}\s*\}')
# [[ spaced wikilink ]] → [[compact]]
DOUBLE_BRACKET_RE = re.compile(r'\[\s*\[\s*(.*?)\s*\]\s*\]')


def compact_inline_tokens(text: str) -> str:
    text = DOUBLE_BRACE_RE.sub(lambda match: '{{' + match.group(1) + '}}', text)
    text = DOUBLE_BRACKET_RE.sub(lambda match: '[[' + match.group(1) + ']]', text)
    return text


def can_unquote_frontmatter(value: str) -> bool:
    if not value:
        return True
    # Always safe to unquote compact placeholders/wikilinks
    if re.fullmatch(r'\{\{[^}]*\}\}', value) or re.fullmatch(r'\[\[[^\]]*\]\]', value):
        return True
    if YAML_AMBIGUOUS_PLAIN_SCALAR_RE.fullmatch(value):
        return False
    if (
        UNSAFE_FRONTMATTER_START_RE.search(value)
        or UNSAFE_FRONTMATTER_INLINE_RE.search(value)
    ):
        return False
    return True


def minify_frontmatter(frontmatter: str) -> str:
    result: list[str] = []

    for line in frontmatter.splitlines(keepends=True):
        if not line.strip():
            continue

        line = compact_inline_tokens(line)

        # key: "value"
        quoted_key_match = re.match(r'^(\s*[\w-]+\s*:\s*)(["\'])(.*)\2(\s*\n?)$', line, re.DOTALL)
        if quoted_key_match:
            prefix, _, value, suffix = quoted_key_match.groups()
            value = compact_inline_tokens(value)
            if can_unquote_frontmatter(value):
                line = prefix + value + suffix
        else:
        # - "list item value"
            quoted_list_match = re.match(r'^(\s*-\s*)(["\'])(.*)\2(\s*\n?)$', line, re.DOTALL)
            if quoted_list_match:
                prefix, _, value, suffix = quoted_list_match.groups()
                value = compact_inline_tokens(value)
                if can_unquote_frontmatter(value):
                    line = prefix + value + suffix
        result.append(line)
    return ''.join(result)


def minify_table_row(line: str) -> str:
    match = TABLE_ROW_RE.match(line)
    if not match:
        return line

    indent, row = match.groups()
    cells = row.split('|')

    if all(re.fullmatch(r'\s*:?-+:?\s*', cell or ' ') for cell in cells):
        compact_cells = [re.sub(r'-+', '-', re.sub(r'\s+', '', cell)) for cell in cells]
    else:
        compact_cells = [cell.strip() for cell in cells]
    return indent + '|' + '|'.join(compact_cells) + '|'


def split_frontmatter(content: str) -> tuple[str, str]:
    fm_match = re.match(r'^(---\n)(.*?)(^---\n)', content, re.DOTALL | re.MULTILINE)
    if fm_match:
        fm_open  = fm_match.group(1)
        fm_body  = minify_frontmatter(fm_match.group(2))
        fm_close = fm_match.group(3)
        body     = content[fm_match.end():]
    else:
        fm_open = fm_body = fm_close = ''
        body = content
    frontmatter = fm_open + fm_body + fm_close
    return frontmatter, body


def minify_body(body: str) -> str:
    output: list[str] = []
    in_fence = False
    for line in body.splitlines():
        stripped = line.strip()

        if FENCE_RE.match(stripped):
            in_fence = not in_fence
            output.append(line.rstrip())
            continue

        if in_fence:
            output.append(line.rstrip())
            continue

        line = line.rstrip()

        if re.match(r'\s*\|', line):
            line = minify_table_row(line)

        line = compact_inline_tokens(line)


        output.append(line)

    compact_body = '\n'.join(output)
    compact_body = re.sub(r'\n{3,}', '\n\n', compact_body)
    compact_body = compact_body.strip('\n') + '\n'

    return compact_body


def minify_markdown(content: str) -> str:
    frontmatter, body = split_frontmatter(content)
    minified_frontmatter = ''


    return frontmatter + minify_body(body)


def discover_files() -> list[Path]:
    files: set[Path] = set()

    for path in REPO_ROOT.rglob('*.md'):
        if any(excluded in path.parts for excluded in EXCLUDED_PARTS):
            continue
        files.add(path)

    return sorted(files)


def normalize_paths(paths: Iterable[str]) -> list[Path]:
    normalized: list[Path] = []

    for raw_path in paths:
        path = Path(raw_path)
        if not path.is_absolute():
            path = (Path.cwd() / path).resolve()
        if path.is_dir():
            normalized.extend(file for file in sorted(path.rglob('*.md')))
        normalized.append(path.resolve())

    deduplicated = []
    seen: set[Path] = set()
    for path in normalized:
        if path in seen:
            continue
        seen.add(path)
        deduplicated.append(path)

    return [path for path in deduplicated if path.exists()]


def check_git_tracked(path: Path) -> bool:
    try:
        completed = subprocess.run(
            ['git', 'ls-files', '--error-unmatch', path.relative_to(REPO_ROOT).as_posix()],
            cwd=REPO_ROOT,
            check=False,
            capture_output=True,
            text=True,
        )
    except ValueError:
        return False

    return completed.returncode == 0


def is_agent_facing_markdown(path: Path) -> bool:
    if path.name not in ('AGENTS.md', 'SKILL.md'):
        return False
    if any(excluded in path.parts for excluded in EXCLUDED_PARTS):
        return False
    return True


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument('--check', action='store_true', help='fail if any file is not minified')
    mode.add_argument('--write', action='store_true', help='rewrite files in place')
    parser.add_argument('paths', nargs='*', help='optional subset of files or directories to process')
    args = parser.parse_args()

    paths = normalize_paths(args.paths) if args.paths else discover_files()
    untracked_paths = [path for path in paths if not check_git_tracked(path)]
    if untracked_paths:
        for path in untracked_paths:
            print(f'skipping untracked file: {path.relative_to(REPO_ROOT).as_posix()}', file=sys.stderr)
        paths = [path for path in paths if path not in untracked_paths]

    changed_paths: list[str] = []

    for path in paths:
        original = path.read_text(encoding='utf-8')
        minified = minify_markdown(original)

        if minified == original:
            continue

        relative_path = path.relative_to(REPO_ROOT).as_posix()
        changed_paths.append(relative_path)

        if args.write:
            path.write_text(minified, encoding='utf-8')

    if args.check and changed_paths:
        print('Agent-facing markdown files are not minified:', file=sys.stderr)
        for relative_path in changed_paths:
            print(f'  - {relative_path}', file=sys.stderr)
        print('Run: python3 .ci/minify_agent_facing_markdown.py --write', file=sys.stderr)
        return 1

    if args.write and changed_paths:
        for relative_path in changed_paths:
            print(f'minified {relative_path}', file=sys.stderr)

    return 0


if __name__ == '__main__':
    raise SystemExit(main())
